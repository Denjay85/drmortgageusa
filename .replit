# .replit  – final + valid
run = "python main.py"

language   = "python3"
entrypoint = "main.py"

[deployment]
run  = ["python", "main.py"]  # Cloud Run uses the same command
port = 8080                   # Replit sets $PORT=8080 in production
deploymentTarget = "cloudrun"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[workflows]

