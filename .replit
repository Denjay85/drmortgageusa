# .replit  – final + valid
run = "python main.py"

language   = "python3"
entrypoint = "main.py"

[deployment]
port = 8080                   # Replit sets $PORT=8080 in production
deploymentTarget = "static"
publicDir = "/"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 34233
externalPort = 3002

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TestServer"

[[workflows.workflow]]
name = "TestServer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "prybar-python3 serve-static.py"
waitForPort = 5000

[agent]
expertMode = true

