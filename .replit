# .replit  – final + valid
run = "python main.py"

language   = "python3"
entrypoint = "main.py"
modules = ["python-3.11", "postgresql-16"]

[deployment]
port = 8080                   # Replit sets $PORT=8080 in production
deploymentTarget = "autoscale"
publicDir = "/"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "app:app"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 34729
externalPort = 6000

[[ports]]
localPort = 35825
externalPort = 8000

[[ports]]
localPort = 36411
externalPort = 6800

[[ports]]
localPort = 40345
externalPort = 5173

[[ports]]
localPort = 40557
externalPort = 4200

[[ports]]
localPort = 40583
externalPort = 3002

[[ports]]
localPort = 40821
externalPort = 5000

[[ports]]
localPort = 41919
externalPort = 3003

[[ports]]
localPort = 42141
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WebServer"

[[workflows.workflow]]
name = "WebServer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

